{
  "name": "cumuluse-repo",
  "version": "0.1.0",
  "description": "Local Codex and Claude Code panel for React apps, with a durable Python backend.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/contracts",
    "packages/cumuluse",
    "packages/react-panel",
    "packages/node-server"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "build:packages": "npm run build --workspaces --if-present",
    "test:packages": "npm test --workspaces --if-present",
    "test": "npm run test:packages"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
